{
  "name": "agentdeck",
  "version": "0.1.0",
  "private": false,
  "bin": {
    "agentdeck": "./dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup && node -e \"require('fs').cpSync('../../apps/web/dist', './dist/web', {recursive: true})\"",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentdeck/adapters": "workspace:*",
    "@agentdeck/shared": "workspace:*",
    "@fastify/cors": "^8.5.0",
    "@fastify/static": "^7.0.4",
    "bonjour-service": "^1.4.1",
    "chokidar": "^5.0.0",
    "fastify": "^4.26.0",
    "fastify-plugin": "^6.0.0",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0",
    "simple-git": "^3.36.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/web-push": "^3.6.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0"
  }
}
