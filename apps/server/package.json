{
  "name": "asterim",
  "version": "0.1.0",
  "private": false,
  "bin": {
    "asterim": "./dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup && node -e \"require('fs').cpSync('../../apps/web/dist', './dist/web', {recursive: true})\"",
