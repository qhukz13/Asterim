    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@asterim/adapters": "workspace:*",
    "@asterim/shared": "workspace:*",
    "@fastify/cors": "^11.3.0",
    "@fastify/static": "^10.1.2",
    "@google/genai": "^2.13.0",
    "bonjour-service": "^1.4.3",
    "chokidar": "^5.0.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0",
    "simple-git": "^3.36.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@asterim/eslint-config": "workspace:^",
    "@types/node": "^26.1.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/web-push": "^3.6.4",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
