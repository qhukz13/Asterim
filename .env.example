# AgentDeck Server Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# ─── Port ──────────────────────────────────────────────────────────────────────
# The port the AgentDeck HTTP/WebSocket server listens on.
# Default: 3000
# PORT=3000

# ─── Database ──────────────────────────────────────────────────────────────────
# Override the directory where agentdeck.db is stored.
# Default: ~/.agentdeck/agentdeck.db
# AGENTDECK_DATA_DIR=/path/to/custom/dir

# ─── Relay Server ──────────────────────────────────────────────────────────────
# The URL of the cloud relay server that proxies remote mobile connections.
# Leave commented out for local development (defaults to localhost:4000).
# For production, point this at your hosted relay instance.
# AGENTDECK_RELAY_URL=https://relay.yourdomain.com

# ─── VAPID Push Notifications ──────────────────────────────────────────────────
# Required for web push notifications to work in production.
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
